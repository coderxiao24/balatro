{
    "name": "@xiaokaixuan/balatro",
    "description": "phaser+capacitor实现的移动端balatro",
    "version": "1.1.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/coderxiao24/balatro.git"
    },
    "author": "xiaokaixuan<xiaokaixuan24@163.com>(https://xiaokaixuan.com/)",
    "license": "MIT",
    "homepage": "https://github.com/coderxiao24/balatro#readme",
    "keywords": [
        "phaser4",
        "balatro",
        "typescript",
        "vite"
    ],
    "scripts": {
        "dev": "vite",
        "dev:prod": "vite --mode production",
        "build": "vite build --mode production",
        "android:build": "npm run build && cross-env CAPACITOR_ENV=production npx cap sync android && cross-env CAPACITOR_ENV=production npx cap open android",
        "android:debug": "cross-env CAPACITOR_ENV=development npx cap sync android &&cross-env CAPACITOR_ENV=development npx cap open android",
        "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,vue,css,scss,json}\""
    },
    "dependencies": {
        "@capacitor/android": "^8.3.4",
        "@capacitor/cli": "^7.6.5",
        "@capacitor/core": "^8.3.4",
        "@capacitor/preferences": "^8.0.1",
        "@xiaokaixuan/random": "^1.1.6",
        "bignumber.js": "^11.1.3",
        "dotenv": "^17.4.2",
        "lodash": "^4.18.1",
        "phaser": "^4.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.22.0",
        "@types/lodash": "^4.17.24",
        "@types/node": "^25.9.1",
        "eslint": "^9.22.0",
        "globals": "^16.0.0",
        "terser": "^5.28.1",
        "typescript": "~5.7.2",
        "typescript-eslint": "^8.26.1",
        "vite": "^6.3.1"
    }
}
