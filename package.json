{
    "name": "template-react-ts",
    "description": "A Phaser 3 TypeScript project template that demonstrates React communication and uses Vite for bundling.",
    "version": "1.1.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/phaserjs/template-react-ts.git"
    },
    "author": "Phaser Studio <support@phaser.io> (https://phaser.io/)",
    "license": "MIT",
    "licenseUrl": "http://www.opensource.org/licenses/mit-license.php",
    "bugs": {
        "url": "https://github.com/phaserjs/template-react-ts/issues"
    },
    "homepage": "https://github.com/phaserjs/template-react-ts#readme",
    "keywords": [
        "phaser",
        "phaser3",
        "react",
        "vite",
        "typescript"
    ],
    "scripts": {
        "dev": "vite",
        "dev:prod": "vite --mode production",
        "build": "vite build --mode production",
        "android:build": "npm run build && cross-env CAPACITOR_ENV=production npx cap sync android && npx cap open android",
        "android:debug": "cross-env CAPACITOR_ENV=development npx cap sync android && npx cap open android",
        "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,vue,css,scss,json}\""
    },
    "dependencies": {
        "@capacitor/android": "^8.3.4",
        "@capacitor/cli": "^7.6.5",
        "@capacitor/core": "^8.3.4",
        "@capacitor/preferences": "^8.0.1",
        "@xiaokaixuan/random": "^1.1.6",
        "bignumber.js": "^11.1.3",
        "dotenv": "^17.4.2",
        "lodash": "^4.18.1",
        "phaser": "^4.1.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.22.0",
        "@types/lodash": "^4.17.24",
        "@types/node": "^25.9.1",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@vitejs/plugin-react": "^4.3.4",
        "eslint": "^9.22.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "globals": "^16.0.0",
        "terser": "^5.28.1",
        "typescript": "~5.7.2",
        "typescript-eslint": "^8.26.1",
        "vite": "^6.3.1"
    }
}
